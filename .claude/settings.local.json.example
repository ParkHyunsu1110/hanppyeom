{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./credentials/**)",
      "Read(./lib/firebase_options.dart)",
      "Read(./android/app/google-services.json)",
      "Read(./ios/Runner/GoogleService-Info.plist)"
    ]
  }
}
